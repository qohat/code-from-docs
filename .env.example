# ---------------------------------------------------------------------------
# Secrets reference — NAMES ONLY. Do NOT put real values here or commit them.
#
# These are configured as GitHub Actions secrets, not read from this file:
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#
# This file exists purely to document which secrets the workflows require.
# ---------------------------------------------------------------------------

# OAuth token for anthropics/claude-code-action (Claude Pro/Max).
# Generate locally with:  claude setup-token
# Used by: reusable-claude.yml
CLAUDE_CODE_OAUTH_TOKEN=

# Discord Incoming Webhook URL for build notifications.
# Discord → Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# Used by: reusable-discord.yml
DISCORD_WEBHOOK_URL=

# Fine-grained PAT so auto-maintain's runner can push and open PRs that TRIGGER
# ci.yml (the Actions GITHUB_TOKEN cannot create PRs, and its PRs don't fire CI).
# Create: GitHub → Settings → Developer settings → Fine-grained tokens →
#   repo = code-from-docs, permissions: Contents = Read/Write, Pull requests = Read/Write.
# Used by: reusable-claude.yml (auto-maintain)
GH_PAT=

# Note: GITHUB_TOKEN is provided automatically by GitHub Actions and is enough
# for generate-backlog (issues) and for commenting on PRs.
